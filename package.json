{
  "name": "construction-sql",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "analyze": "nuxi analyze",
    "dev": "dotenvx run -- node -e \"process.env.PORT=process.env.NUXT_DEV_SERVER_PORT||process.env.PORT||'3000'; require('child_process').execSync('nuxt dev', {stdio:'inherit', env:process.env});\"",
    "generate": "nuxt generate",
    "preview": "dotenvx run -- node -e \"process.env.PORT=process.env.NUXT_DEV_SERVER_PORT||'3000'; require('child_process').execSync('nuxt preview', {stdio:'inherit', env:process.env});\"",
    "start": "dotenvx run -- node -e \"process.env.PORT=process.env.NUXT_DEV_SERVER_PORT||'3000'; require('child_process').execSync('node .output/server/index.mjs', {stdio:'inherit', env:process.env});\"",
    "postinstall": "nuxt prepare && prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "dotenvx run -- node scripts/run-prisma.mjs migrate deploy",
    "db:migrate:dev": "dotenvx run -- node scripts/run-prisma.mjs migrate dev",
    "db:migrate:status": "dotenvx run -- node scripts/run-prisma.mjs migrate status",
    "db:studio": "dotenvx run -- node scripts/run-prisma.mjs studio",
    "db:push": "dotenvx run -- node scripts/run-prisma.mjs db push",
    "db:sync:supabase": "dotenvx run -- node scripts/supabase-to-mssql/index.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit:components": "vitest run test/unit/components/",
    "test:unit:stores": "vitest run test/unit/stores/",
    "test:unit:api": "vitest run test/unit/api/",
    "test:unit:composables": "vitest run test/unit/composables/"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@nuxt/ui": "^4.8.0",
    "@pinia/nuxt": "^0.11.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/extension-image": "^3.12.1",
    "@tiptap/extension-link": "^3.12.1",
    "@tiptap/extension-placeholder": "^3.12.1",
    "@tiptap/extension-text-align": "^3.12.1",
    "@tiptap/starter-kit": "^3.12.1",
    "@tiptap/vue-3": "^3.12.1",
    "@types/papaparse": "^5.3.16",
    "@vueuse/integrations": "^14.0.0",
    "chart.js": "^4.5.0",
    "country-flag-icons": "^1.5.20",
    "dayjs": "^1.11.18",
    "dexie": "^4.2.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "mssql": "^12.5.4",
    "nodemailer": "^8.0.3",
    "nuxt": "^4.4.6",
    "nuxt-tiptap-editor": "^3.0.0",
    "papaparse": "^5.5.3",
    "pg": "^8.22.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sortablejs": "^1.15.6",
    "tailwindcss": "^4.1.14",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.2",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.2",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.117",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.6",
    "jsdom": "^25.0.1",
    "prisma": "^6.19.3",
    "vitest": "^3.2.4"
  }
}
