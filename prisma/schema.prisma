generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

/// Freight master (carriers / shipping methods).
model Freight {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  // Your existing DB column is still `ship_via` (legacy naming). We map it to
  // Prisma field `freight_name` so the app can use `freight_name`.
  freight_name String   @map("ship_via") @unique @db.NVarChar(255)
  description  String?  @db.NVarChar(Max)
  active       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.DateTime2
  updated_at   DateTime @updatedAt @db.DateTime2
  created_by   String?  @db.NVarChar(128)
  updated_by   String?  @db.NVarChar(128)

  @@index([active])
  @@index([created_at(sort: Desc)])
  @@map("freight")
}

/// Approval checks master data.
model ApprovalCheck {
  id             BigInt   @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  approval_check String   @unique @db.NVarChar(255)
  description    String?  @db.NVarChar(Max)
  active         Boolean  @default(true)
  created_at     DateTime @default(now()) @db.DateTime2
  updated_at     DateTime @updatedAt @db.DateTime2
  created_by     String?  @db.NVarChar(128)
  updated_by     String?  @db.NVarChar(128)

  @@index([active])
  @@index([created_at(sort: Desc)])
  @@map("approval_checks")
}

/// Location master data.
model Location {
  id            BigInt   @id @default(autoincrement())
  uuid          String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  location_name String   @db.NVarChar(255)
  location_code String?  @db.NVarChar(64)
  description   String?  @db.NVarChar(Max)
  active        Boolean  @default(true)
  created_at    DateTime @default(now()) @db.DateTime2
  updated_at    DateTime @updatedAt @db.DateTime2
  created_by    String?  @db.NVarChar(128)
  updated_by    String?  @db.NVarChar(128)

  @@unique([location_name], map: "location_location_name_key")
  @@index([active])
  @@index([created_at(sort: Desc)])
  @@map("location")
}

/// Purchase order instructions scoped by corporation.
model POInstruction {
  id                  BigInt   @id @default(autoincrement())
  uuid                String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  corporation_uuid    String   @db.NVarChar(64)
  po_instruction_name String   @db.NVarChar(255)
  instruction         String   @db.NVarChar(Max)
  status              String   @default("ACTIVE") @db.NVarChar(20)
  created_at          DateTime @default(now()) @db.DateTime2
  updated_at          DateTime @updatedAt @db.DateTime2
  created_by          String?  @db.NVarChar(128)
  updated_by          String?  @db.NVarChar(128)

  @@index([corporation_uuid])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("po_instructions")
}

/// Reason master data (global, non-corporation-specific).
model Reason {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  reason     String   @db.NVarChar(Max)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.DateTime2
  updated_at DateTime @updatedAt @db.DateTime2
  created_by String?  @db.NVarChar(128)
  updated_by String?  @db.NVarChar(128)

  @@index([active])
  @@index([created_at(sort: Desc)])
  @@map("reasons")
}

/// Global project types shared across corporations.
model ProjectType {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  name        String   @unique @db.NVarChar(255)
  description String?  @db.NVarChar(Max)
  color       String   @default("#3B82F6") @db.NVarChar(7)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime2
  updated_at  DateTime @updatedAt @db.DateTime2
  created_by  String?  @db.NVarChar(128)
  updated_by  String?  @db.NVarChar(128)

  @@index([is_active])
  @@index([created_at(sort: Desc)])
  @@map("project_types")
}

/// Global service types shared across corporations.
model ServiceType {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  name        String   @unique @db.NVarChar(255)
  description String?  @db.NVarChar(Max)
  color       String   @default("#3D5C7C") @db.NVarChar(7)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime2
  updated_at  DateTime @updatedAt @db.DateTime2
  created_by  String?  @db.NVarChar(128)
  updated_by  String?  @db.NVarChar(128)

  @@index([is_active])
  @@index([created_at(sort: Desc)])
  @@map("service_types")
}

/// Global terms and conditions templates.
model TermsAndCondition {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("NEWID()")) @db.UniqueIdentifier
  name       String   @unique @db.NVarChar(255)
  content    String   @db.NVarChar(Max)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.DateTime2
  updated_at DateTime @updatedAt @db.DateTime2
  created_by String?  @db.NVarChar(128)
  updated_by String?  @db.NVarChar(128)

  @@index([is_active])
  @@index([name])
  @@index([created_at(sort: Desc)])
  @@map("terms_and_conditions")
}
