  project_document_uuid String  @db.NVarChar(36)
  tag                  String   @db.NVarChar(100)
  created_at           DateTime @default(now()) @db.DateTime2

  document ProjectDocument @relation(fields: [project_document_uuid], references: [uuid], onDelete: Cascade)

  @@unique([project_document_uuid, tag])
  @@index([project_document_uuid])
  @@map("project_document_tags")
}
