# Server port for dev (nuxt dev), preview (nuxt preview), and start
NUXT_DEV_SERVER_PORT=3000
# MSSQL (server-side only — never use NUXT_PUBLIC_ prefix)
# Server=10.4.1.12;Database=supabase;Trusted_Connection=True;TrustServerCertificate=true;User ID=sa;Password=***;Integrated Security=False;MultipleActiveResultSets=True
NUXT_MSSQL_CONNECTION_STRING="Server=10.4.1.12;Database=supabase;Trusted_Connection=True;TrustServerCertificate=true;User ID=sa;Password=^!ml3Le#543*;Integrated Security=False;MultipleActiveResultSets=True"
NUXT_PUBLIC_NIMBLE_INTEGRATIONS=false
# Nimble – required for integration (set in .env; no fallbacks in code)
NUXT_PUBLIC_NIMBLE_OAUTH_EXCHANGE_URL=https://qa-api-usermgmt.nimbleproperty.net
NUXT_PUBLIC_NIMBLE_CORE_API_URL=https://qa-api-core.nimbleproperty.net
NIMBLE_API3_URL=https://qa-api3.nimbleproperty.net
NIMBLE_API_BASE_URL=https://qa-api5.nimbleproperty.net
# App base URL used to build Nimble BillEntrySave CallBackUrl
APPLICATION_URL=https://nimble-construction.kodefast.com
# Used only to derive host (origin); full vendor dialog path is built in code: /payable/launchscreen/vendordialog/...
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_BASE_URL=https://qa-payableui2.nimbleproperty.net/payable/launchscreen/vendordialog
# Path segment for Nimble Payable vendor iframe: /{env}/payable/vendor/{env}/...
NUXT_PUBLIC_NIMBLE_PAYABLE_ENV=qa22
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_MENU_ID=010000000000000000000000000000000330
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_CORPORATION_ID=C6B98A4ACF2546974D533674FDD8360D0000


# Nimble webhooks: shared secret for corporations-sync. If set, Nimble must send it in Authorization: Bearer <secret> or X-Nimble-Webhook-Secret header.
NIMBLE_WEBHOOK_SECRET=qZ7mTr4Yx2PwNc6Bj8HvDs5LkEa
