# Server port for dev (nuxt dev), preview (nuxt preview), and start
NUXT_DEV_SERVER_PORT=3000

# Construction accounting MSSQL (Prisma + app) — Database=supabase
NUXT_CONSTRUCTION_ACCOUNTING_CONNECTION_STRING="Server=10.4.1.12;Database=supabase;TrustServerCertificate=true;User ID=sa;Password=your-password;Integrated Security=False;MultipleActiveResultSets=True"
# Nimble property MSSQL (schema docs only until wired) — e.g. Database=Sunray_06022026
NUXT_NIMBLE_CONNECTION_STRING="Server=10.4.1.12;Database=Sunray_06022026;TrustServerCertificate=true;User ID=sa;Password=your-password;Integrated Security=False;MultipleActiveResultSets=True"
# Legacy alias — same as construction accounting
NUXT_MSSQL_CONNECTION_STRING="Server=10.4.1.12;Database=supabase;TrustServerCertificate=true;User ID=sa;Password=your-password;Integrated Security=False;MultipleActiveResultSets=True"

# Nimble – required for integration
# Login: {NUXT_PUBLIC_NIMBLE_OAUTH_EXCHANGE_URL}/v1/OpenApiauth/Login (payload url = NUXT_PUBLIC_NIMBLE_PAYABLE_ENV)
NUXT_PUBLIC_NIMBLE_OAUTH_EXCHANGE_URL=https://qa-api-usermgmt.nimbleproperty.net
NUXT_PUBLIC_NIMBLE_PAYABLE_ENV=qa22
NUXT_PUBLIC_NIMBLE_CORE_API_URL=
NIMBLE_API3_URL=
NIMBLE_API_BASE_URL=
APPLICATION_URL=
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_BASE_URL=
NUXT_PUBLIC_NIMBLE_PAYABLE_ENV=
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_MENU_ID=
NUXT_PUBLIC_NIMBLE_VENDOR_POPUP_CORPORATION_ID=

NIMBLE_WEBHOOK_SECRET=
# Optional: signs auth session cookie (defaults to NIMBLE_WEBHOOK_SECRET)
NUXT_AUTH_SESSION_SECRET=

# Amazon SES SMTP (server-side only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_REGISTRATION=
SMTP_CONTACT_US=

# Supabase (Postgres) — for on-demand sync: npm run db:sync:supabase
# Use the direct Database connection string (Settings → Database), not the REST URL alone.
NUXT_SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
NUXT_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NUXT_SUPABASE_ANON_KEY=
NUXT_SUPABASE_SERVICE_ROLE_KEY=
